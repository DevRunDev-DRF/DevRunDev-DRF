# 개발용 환경 설정 예시 파일 (.env.example)
# 실제 값을 채워서 .env로 복사하여 사용하세요.

# 개발 중 디버그 모드: True / 배포 시 반드시 False
DEBUG=True

# Django SECRET_KEY: 개발용으로는 임의의 키 사용 가능
SECRET_KEY=your-secret-key-here

# SQLite 또는 PostgreSQL 등 DB 연결 정보
# 예: sqlite:///db.sqlite3 또는 postgres://user:password@host:port/dbname
DATABASE_URL=sqlite:///db.sqlite3

# 허용할 도메인 (쉼표로 구분)
# 예: localhost,127.0.0.1 또는 yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

IAMPORT_API_KEY=
IAMPORT_API_SECRET=